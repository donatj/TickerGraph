{
    "compilerOptions": {
        "declaration": true,
        "declarationDir": "lib",
        "emitDeclarationOnly": true,
        "alwaysStrict": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2015",
        "noImplicitAny": true,
        "strictNullChecks": true,
        "sourceMap": true,
        "strict": true,
        "rootDir": "./src"
    },
    "include": [
        "src/**/*.ts"
    ]
}