{
  "name": "ticker-graph",
  "description": "Simple Ticker Graph",
  "type": "module",
  "main": "./lib/TickerGraph.cjs",
  "module": "./lib/TickerGraph.mjs",
  "browser": "./lib/TickerGraph.js",
  "unpkg": "./lib/TickerGraph.min.js",
  "exports": {
    ".": {
      "types": "./lib/TickerGraph.d.ts",
      "browser": "./lib/TickerGraph.js",
      "import": "./lib/TickerGraph.mjs",
      "require": "./lib/TickerGraph.cjs",
      "default": "./lib/TickerGraph.mjs"
    }
  },
  "version": "0.3.0",
  "types": "./lib/TickerGraph.d.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "tslint -c tslint.json src/**/*.ts",
    "clean": "rm -rf lib",
    "build": "rollup -c rollup.config.mjs",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir lib",
    "build:all": "npm run build && npm run build:types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donatj/TickerGraph.git"
  },
  "keywords": [
    "Ticker",
    "Graph"
  ],
  "author": {
    "name": "Jesse G. Donat",
    "email": "donatj@gmail.com",
    "url": "https://donatstudios.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/donatj/TickerGraph/issues"
  },
  "homepage": "https://github.com/donatj/TickerGraph#readme",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.4",
    "tslint": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
